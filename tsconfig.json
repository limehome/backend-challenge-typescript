{
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./build",
        "rootDir": "./src",
        "target": "ES2022",
        "lib": ["ES2022"],
        "skipLibCheck": true,
        "strict": true,
        "resolveJsonModule": true
    }
}
